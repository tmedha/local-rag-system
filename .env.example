# CloakedOracle configuration — copy to .env and edit as needed.

# Ollama (local LLM runtime)
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2
# Low temperature (0-1) keeps answers faithful to the documents. Default 0.1.
LLM_TEMPERATURE=0.1

# Local embedding model (sentence-transformers, runs in-process). Changing this triggers
# an automatic full re-index of the vault on next start.
EMBED_MODEL=all-MiniLM-L6-v2
# Instruction prefix applied to QUERIES only (bge-style models want one; all-MiniLM does
# not, so leave it blank).
QUERY_PREFIX=

# Retrieval / chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
# Relevance gating for retrieved passages (cosine similarity, 0-1).
# MIN_SCORE = absolute floor; RELEVANCE_MARGIN = how far below the best hit is still kept.
MIN_SCORE=0.15
RELEVANCE_MARGIN=0.15
# Session uploads are prioritized: reserve up to UPLOAD_RESERVE upload chunks (above the
# tiny UPLOAD_MIN_SCORE floor) so a file you uploaded for this chat is always consulted.
UPLOAD_RESERVE=2
UPLOAD_MIN_SCORE=0.05

# Chat history
HISTORY_TURNS=6
MAX_SESSIONS=100
