# CloakedOracle configuration — copy to .env and edit as needed.

# Ollama (local LLM runtime)
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2
# Low temperature (0-1) keeps answers faithful to the documents. Default 0.1.
LLM_TEMPERATURE=0.1

# Local embedding model (sentence-transformers, runs in-process)
EMBED_MODEL=all-MiniLM-L6-v2

# Retrieval / chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
# Minimum cosine similarity (0-1) a passage must clear to count as relevant evidence.
MIN_SCORE=0.35

# Chat history
HISTORY_TURNS=6
MAX_SESSIONS=100
